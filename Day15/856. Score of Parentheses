class Solution {
    public int scoreOfParentheses(String s) {
        Stack<Integer> st = new Stack<>();
        st.push(0);
        for(int i =0;i<s.length();i++){
            if(s.charAt(i)=='('){
                st.push(0);
            }
            else{
                int inside = st.pop();
                int score = Math.max(2*inside,1);
                int pre = st.pop();
                st.push(pre+score);
            }
        }
        return st.pop();
    }
}
